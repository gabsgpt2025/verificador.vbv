# ── Supabase (public — safe to expose to the browser) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Auth toggle ────────────────────────────────────────────────────────────────
# Set to "true" to enable login enforcement.
# When unset or "false" the app runs in open-access (guest) mode.
NEXT_PUBLIC_REQUIRE_AUTH=false

# ── OAuth redirect URL (development only) ──────────────────────────────────────
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ── Neutrino API (server-side only — never prefix with NEXT_PUBLIC_) ────────────
# Both keys must be set together.
# Sign up at https://www.neutrinoapi.com/
# Keep secrets only in environment variables (never in markdown/docs).
# Required for BIN lookup used by `/api/bin-analysis-v2`.
NEUTRINO_USER_ID=<your-neutrino-user-id>
NEUTRINO_API_KEY=<your-neutrino-api-key>

# ── Mastercard API (server-side only) ──────────────────────────────────────────
# Obtain credentials from https://developer.mastercard.com/
MASTERCARD_CONSUMER_KEY=<your-mastercard-consumer-key>
MASTERCARD_SANDBOX_CLIENT_ID=<your-mastercard-sandbox-client-id>
MASTERCARD_KEY_ALIAS=<your-key-alias>
MASTERCARD_KEY_PASSWORD=<your-key-password>
MASTERCARD_P12_PATH=<path-to-your-p12-file>
# Or supply the base64-encoded P12 certificate directly:
# MASTERCARD_P12_CERT=<base64-encoded-p12>
# Set to "false" to use the Mastercard production environment.
MASTERCARD_SANDBOX_MODE=true
