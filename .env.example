# ============================================================
# .env.example — VeriFiBIN Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# === Supabase (obrigatório) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Auth ===
# Quando "true", força login obrigatório em todas as rotas protegidas.
# Quando ausente ou "false", modo open-access (acesso sem login).
NEXT_PUBLIC_REQUIRE_AUTH=false

# Redirect URL utilizada no fluxo de confirmação de e-mail (desenvolvimento local).
# Em produção a Vercel detecta automaticamente a URL correta.
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# === Neutrino API (BIN Lookup) — https://www.neutrinoapi.com/ ===
# Necessário para que /api/bin-analysis-v2 use dados reais (sem isso, cai no fallback simulado).
# Ambas as variáveis devem ser definidas juntas ou nenhuma das duas.
NEUTRINO_API_KEY=your_neutrino_api_key_here
NEUTRINO_USER_ID=your_neutrino_user_id_here

# === Mastercard APIs (opcional) ===
# MASTERCARD_CONSUMER_KEY=
# MASTERCARD_SANDBOX_CLIENT_ID=
# MASTERCARD_KEY_ALIAS=
# MASTERCARD_KEY_PASSWORD=
# MASTERCARD_P12_PATH=
# MASTERCARD_P12_CERT=
# MASTERCARD_SANDBOX_MODE=true

# === AI / xAI (opcional) ===
# XAI_API_KEY=
