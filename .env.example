# ── Supabase (public — safe to expose to the browser) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Auth toggle ────────────────────────────────────────────────────────────────
# "true" para exigir autenticação (recomendado em produção). Default: aberto.
NEXT_PUBLIC_REQUIRE_AUTH=false

# ── OAuth redirect URL (development only) ──────────────────────────────────────
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ── Credits testing mode (server-side only) ─────────────────────────────────────
# Apenas para desenvolvimento local. NUNCA setar como true em produção.
CREDITS_TESTING_MODE=false

# ── Admin runtime metrics (server-side only) ────────────────────────────────────
# Opcional. Quando ausente, /api/admin/runtime-metrics retorna 503 (disabled).
ADMIN_METRICS_KEY=

# ── Neutrino API (server-side only — never prefix with NEXT_PUBLIC_) ────────────
# Neutrino API — https://www.neutrinoapi.com/ (obrigatórias para análise BIN real)
NEUTRINO_API_KEY=
NEUTRINO_USER_ID=
# Feature flags adicionais Neutrino (Tier 1) — default OFF para proteger quota diária.
# IP Info (10K/dia) — geolocalização de IP
NEUTRINO_IP_INFO_ENABLED=false
# IP Blocklist (10K/dia) — listas de spam/proxy/Tor
NEUTRINO_IP_BLOCKLIST_ENABLED=false
# IP Probe (1K/dia) — proxy/VPN/hosting/bogon
NEUTRINO_IP_PROBE_ENABLED=false
# UA Lookup (10K/dia) — parser confiável de user-agent / bot
NEUTRINO_UA_LOOKUP_ENABLED=false
# Host Reputation (500/dia) — reputação de domínio do merchant
NEUTRINO_HOST_REPUTATION_ENABLED=false
NEUTRINO_EMAIL_VALIDATE_ENABLED=false
NEUTRINO_PHONE_VALIDATE_ENABLED=false
NEUTRINO_BAD_WORD_FILTER_ENABLED=false
NEUTRINO_BROWSER_BOT_ENABLED=false
NEUTRINO_HTML_CLEAN_ENABLED=false
NEUTRINO_URL_INFO_ENABLED=false
NEUTRINO_HLR_LOOKUP_ENABLED=false
NEUTRINO_PHONE_VERIFY_ENABLED=false
NEUTRINO_SMS_VERIFY_ENABLED=false
NEUTRINO_VERIFY_SECURITY_CODE_ENABLED=false
NEUTRINO_PHONE_PLAYBACK_ENABLED=false
NEUTRINO_GEOCODE_ADDRESS_ENABLED=false
NEUTRINO_GEOCODE_REVERSE_ENABLED=false
NEUTRINO_DOMAIN_LOOKUP_ENABLED=false
NEUTRINO_EMAIL_VERIFY_ENABLED=false
NEUTRINO_IP_BLOCKLIST_DOWNLOAD_ENABLED=false
NEUTRINO_BIN_LIST_DOWNLOAD_ENABLED=false
NEUTRINO_CURRENCY_CONVERT_ENABLED=false
NEUTRINO_HTML_RENDER_ENABLED=false
NEUTRINO_IMAGE_RESIZE_ENABLED=false
NEUTRINO_IMAGE_WATERMARK_ENABLED=false
NEUTRINO_QR_CODE_ENABLED=false

# ── Neutrino API — Data Tools ────────────────────────────────────────────────────
# Bad Word Filter — filtragem de palavras inapropriadas
NEUTRINO_BAD_WORD_FILTER_ENABLED=false
# Email Validate — validação de formato e MX de email
NEUTRINO_EMAIL_VALIDATE_ENABLED=false
# Phone Validate — validação de número de telefone
NEUTRINO_PHONE_VALIDATE_ENABLED=false

# ── Neutrino API — E-commerce ────────────────────────────────────────────────────
# BIN List Download — download da lista de BINs em CSV
NEUTRINO_BIN_LIST_DOWNLOAD_ENABLED=false
# Convert — conversão de unidades/moedas
NEUTRINO_CONVERT_ENABLED=false

# ── Neutrino API — Geolocation ───────────────────────────────────────────────────
# Geocode Address — geocodificação de endereço para coordenadas
NEUTRINO_GEOCODE_ADDRESS_ENABLED=false
# Geocode Reverse — geocodificação reversa de coordenadas para endereço
NEUTRINO_GEOCODE_REVERSE_ENABLED=false

# ── Neutrino API — Imaging ───────────────────────────────────────────────────────
# HTML Render — renderização de HTML para PDF/PNG
NEUTRINO_HTML_RENDER_ENABLED=false
# Image Resize — redimensionamento de imagem
NEUTRINO_IMAGE_RESIZE_ENABLED=false
# Image Watermark — adição de marca d'água em imagem
NEUTRINO_IMAGE_WATERMARK_ENABLED=false
# QR Code — geração de QR Code
NEUTRINO_QR_CODE_ENABLED=false

# ── Neutrino API — Security and Networking ───────────────────────────────────────
# Domain Lookup — informações de domínio (WHOIS, DNS)
NEUTRINO_DOMAIN_LOOKUP_ENABLED=false
# Email Verify — verificação de caixa postal real de email
NEUTRINO_EMAIL_VERIFY_ENABLED=false
# IP Blocklist Download — download de lista de IPs bloqueados
NEUTRINO_IP_BLOCKLIST_DOWNLOAD_ENABLED=false

# ── Neutrino API — Telephony ─────────────────────────────────────────────────────
# HLR Lookup — consulta HLR (Home Location Register) de número de celular
NEUTRINO_HLR_LOOKUP_ENABLED=false
# Phone Playback — reprodução de áudio via chamada telefônica
NEUTRINO_PHONE_PLAYBACK_ENABLED=false
# Phone Verify — verificação de número via chamada telefônica
NEUTRINO_PHONE_VERIFY_ENABLED=false
# SMS Verify — verificação de número via SMS
NEUTRINO_SMS_VERIFY_ENABLED=false
# Verify Security Code — validação de código de segurança enviado
NEUTRINO_VERIFY_SECURITY_CODE_ENABLED=false

# ── Neutrino API — WWW ───────────────────────────────────────────────────────────
# Browser Bot — extração de conteúdo via headless browser
NEUTRINO_BROWSER_BOT_ENABLED=false
# HTML Clean — limpeza e sanitização de HTML
NEUTRINO_HTML_CLEAN_ENABLED=false
# URL Info — informações sobre URL (redirect, status, etc.)
NEUTRINO_URL_INFO_ENABLED=false

# ── Neutrino API — Util ──────────────────────────────────────────────────────────
# Multi — execução de múltiplos endpoints em uma só chamada
NEUTRINO_MULTI_ENABLED=false
# Ping — verificação de disponibilidade de host
NEUTRINO_PING_ENABLED=false
# Stats — estatísticas de uso da conta Neutrino
NEUTRINO_STATS_ENABLED=false

# ── Upstash Redis (server-side only — optional, install when enabling) ──────────
# UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>

# ── FraudLabs Pro API (server-side only) ────────────────────────────────────────
# https://www.fraudlabspro.com/ — Micro plan: 500 queries/mês (gratuito)
# FRAUDLABS_ENABLED=false — setar true APENAS quando a API key for válida
FRAUDLABS_PRO_API_KEY=
FRAUDLABS_ENABLED=false

# ── Mastercard API (server-side only) ──────────────────────────────────────────
# Obtain credentials from https://developer.mastercard.com/
MASTERCARD_CONSUMER_KEY=
MASTERCARD_PRIVATE_KEY=
MASTERCARD_KEY_ALIAS=keyalias
MASTERCARD_KEY_PASSWORD=keystorepassword
MASTERCARD_API_BASE=https://sandbox.api.mastercard.com
