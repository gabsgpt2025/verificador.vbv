{
  "env": {
    "NEUTRINO_USER_ID": "@neutrino_user_id",
    "NEUTRINO_API_KEY": "@neutrino_api_key",
    "MASTERCARD_SANDBOX_CLIENT_ID": "@mastercard_sandbox_client_id",
    "MASTERCARD_CONSUMER_KEY": "@mastercard_consumer_key",
    "MASTERCARD_P12_CERT": "@mastercard_p12_cert",
    "MASTERCARD_KEY_PASSWORD": "@mastercard_key_password",
